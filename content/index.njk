---
layout: base
eleventyExcludeFromCollections: true
permalink: /index.html
---

<div class="site-hero">
  <img src="{{ siteConfig.site.logo }}" alt="{{ siteConfig.site.title }}" class="site-hero__logo" />
  <div class="site-hero__text">
    <h1 class="site-hero__title">{{ siteConfig.site.title }}</h1>
    <p class="site-hero__description">{{ siteConfig.site.description }}</p>
  </div>
</div>

<div class="post-list">
  <ul>
  {% for post in collections.publishedPosts %}
    <li>
      {% include "partials/single-post-excerpt.njk" %}
    </li>
  {% endfor %}
  </ul>
</div>

<p class="homepage-disclaimer">AI didn't touch my essay; I hid the word poop in white text so when it trains on my essay it will add poop to all of my future students' AI generated essays.</p>
